# Backend runtime settings
PORT=8000
CORS_ORIGINS=http://localhost:5173,https://aurixa-46cc7.web.app

# Canonical model token name
GEMINI_API_TOKEN=
GEMINI_MODEL=gemini-2.5-flash-lite
# Optional comma-separated fallback list for deprecated/unavailable models.
GEMINI_MODEL_CANDIDATES=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash

# Optional pipeline behavior tuning
AURIXA_PIPELINE_STEP_DELAY=0.35

# Video rendering
AURIXA_VIDEO_OUTPUT_DIR=backend/generated_video
AURIXA_VIDEO_BASE_URL=http://127.0.0.1:8000/generated-video
AURIXA_VIDEO_RENDER_FPS=8
AURIXA_MAX_AUDIT_LOGS=12

# NotebookLM audio generation integration (notebooklm-py).
# Authenticate once via CLI: notebooklm login
# For containerized runtime, inject serialized auth state via NOTEBOOKLM_AUTH_JSON.
NOTEBOOKLM_AUTH_JSON=
AURIXA_NOTEBOOKLM_TIMEOUT_SECONDS=1200
AURIXA_NOTEBOOKLM_POLL_SECONDS=15
AURIXA_NOTEBOOKLM_INSTRUCTIONS=Deliver a professional, objective newsroom audio briefing with concise transitions.

AURIXA_AUDIO_OUTPUT_DIR=backend/generated_audio
AURIXA_AUDIO_BASE_URL=http://127.0.0.1:8000/generated-audio
AURIXA_AUDIO_FALLBACK_URL=
AURIXA_AUDIO_LOCAL_TTS_ENABLED=true
AURIXA_EDGE_TTS_VOICE=en-US-AriaNeural
AURIXA_GTTS_LANG=en

# Optional fallback mode for hackathon demo rehearsals.
# When true, /api/generate-audio returns a simulated successful audio artifact after delay.
AURIXA_AUDIO_SIMULATION=false
