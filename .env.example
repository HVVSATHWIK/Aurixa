# Frontend stream mode: auto | websocket | polling
VITE_AURIXA_STREAM_MODE=auto

# Gemini token naming
# Server-side preferred token variable:
GEMINI_API_TOKEN=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MODEL_CANDIDATES=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-2.0-flash

# Firebase Web SDK config (copy from Firebase Project Settings -> Web App)
VITE_FIREBASE_API_KEY=AIzaSyCtldTk8C2cSbGe4MrNUBEO6GGXarlb8NA
VITE_FIREBASE_AUTH_DOMAIN=aurixa-46cc7.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=aurixa-46cc7
VITE_FIREBASE_STORAGE_BUCKET=aurixa-46cc7.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=206089236049
VITE_FIREBASE_APP_ID=1:206089236049:web:660f672032e6031c1b1270
VITE_FIREBASE_MEASUREMENT_ID=G-0D1CW67L44

# WebSocket endpoint that emits JSON state updates
# Example payloads accepted:
# 1) { ...state }
# 2) { "state": { ...state } }
# 3) { "payload": { ...state } }
VITE_AURIXA_WS_URL=ws://127.0.0.1:8000/ws/state

# HTTP endpoint that returns JSON state snapshots
# Same payload formats as above are supported.
VITE_AURIXA_POLL_URL=http://127.0.0.1:8000/api/state

# Optional explicit API endpoints. If left empty, frontend derives these from VITE_AURIXA_POLL_URL.
VITE_AURIXA_ANALYZE_URL=http://127.0.0.1:8000/api/analyze
VITE_AURIXA_AUDIO_URL=http://127.0.0.1:8000/api/generate-audio
VITE_AURIXA_AUDIO_JOB_BASE_URL=http://127.0.0.1:8000/api/audio-jobs
VITE_AURIXA_NAVIGATOR_QA_URL=http://127.0.0.1:8000/api/navigator-question
VITE_AURIXA_VIDEO_BRIEF_URL=http://127.0.0.1:8000/api/generate-video-brief
VITE_AURIXA_VIDEO_JOB_BASE_URL=http://127.0.0.1:8000/api/video-jobs

# Optional backend origin override for zero-config local setups.
# If omitted, frontend auto-detects backend origin:
# - local dev defaults to http://127.0.0.1:8000
# - deployed builds default to current site origin
VITE_AURIXA_BACKEND_ORIGIN=

# Timing controls (milliseconds)
VITE_AURIXA_POLL_INTERVAL_MS=2000
VITE_AURIXA_WS_RECONNECT_MS=2000
VITE_AURIXA_SIMULATION_INTERVAL_MS=2200
